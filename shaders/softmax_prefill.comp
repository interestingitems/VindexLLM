#version 450

// Prefill Softmax: normalize attention scores for all (head, query_pos) pairs.
// Each workgroup processes one (head, query_pos) slice of NumTokens keys.
// Causal mask is already applied (masked positions are -1e30).
//
// Scores layout: [NumQHeads x NumTokens x NumTokens]
//   slice(head, qpos) at offset: head * N * N + qpos * N
//
// Dispatch 2D: (NumQHeads, NumTokens) — one workgroup per (head, query_pos)
//   X = query head, Y = query position
//
// Bindings:
//   0 = scores (float[], read/write in-place)
//
// Push constants:
//   num_tokens  = keys per slice (and stride between query rows)
//   num_q_heads = number of query heads

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PushConstants {
    uint num_tokens;
    uint num_q_heads;
} pc;

layout(std430, binding = 0) buffer ScoresBuf {
    float scores[];
};

shared float shared_data[256];

void main() {
    uint head = gl_WorkGroupID.x;
    uint q_pos = gl_WorkGroupID.y;
    uint tid = gl_LocalInvocationID.x;

    if (head >= pc.num_q_heads || q_pos >= pc.num_tokens)
        return;

    uint N = pc.num_tokens;
    uint base = head * N * N + q_pos * N;

    // Phase 1: Find max (parallel reduction)
    float local_max = -1.0e30;
    for (uint i = tid; i < N; i += 256) {
        local_max = max(local_max, scores[base + i]);
    }
    shared_data[tid] = local_max;
    barrier();

    for (uint stride = 128; stride > 0; stride >>= 1) {
        if (tid < stride)
            shared_data[tid] = max(shared_data[tid], shared_data[tid + stride]);
        barrier();
    }
    float max_val = shared_data[0];
    barrier();

    // Phase 2: Compute exp(x - max) in-place and sum
    float local_sum = 0.0;
    for (uint i = tid; i < N; i += 256) {
        float e = exp(scores[base + i] - max_val);
        scores[base + i] = e;
        local_sum += e;
    }
    shared_data[tid] = local_sum;
    barrier();

    for (uint stride = 128; stride > 0; stride >>= 1) {
        if (tid < stride)
            shared_data[tid] += shared_data[tid + stride];
        barrier();
    }
    float total_sum = shared_data[0];
    barrier();

    // Phase 3: Normalize
    float inv_sum = 1.0 / total_sum;
    for (uint i = tid; i < N; i += 256) {
        scores[base + i] *= inv_sum;
    }
}
