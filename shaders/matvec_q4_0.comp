#version 450

// MatVec Q4_0: multiply a Q4_0 weight matrix by an F32 input vector.
// One invocation per output row. Each thread computes the dot product
// of one quantized row with the F32 input vector.
//
// Q4_0 block format (18 bytes, 32 elements):
//   bytes 0-1:  f16 scale factor
//   bytes 2-17: 16 uint8 values, each packing 2 × 4-bit quantized values
//   dequant: value = (nibble - 8) * scale
//
// Weight buffer is accessed as uint[] (raw bytes packed as uint32).
// Block boundaries do NOT align to 4 bytes (18 is not a multiple of 4),
// so we extract bytes manually via shift+mask.
//
// Bindings:
//   0 = weight matrix (uint[], raw Q4_0 blocks, row-major)
//   1 = input vector (float[], in_dim elements)
//   2 = output vector (float[], out_dim elements)
//
// Push constants:
//   in_dim  = input dimension (must be multiple of 32)
//   out_dim = output dimension

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PushConstants {
    uint in_dim;
    uint out_dim;
} pc;

layout(std430, binding = 0) readonly buffer WeightBuf {
    uint weight_data[];
};

layout(std430, binding = 1) readonly buffer InputBuf {
    float input_vec[];
};

layout(std430, binding = 2) writeonly buffer OutputBuf {
    float output_vec[];
};

// Read one byte from the uint[] buffer at the given byte offset
uint read_byte(uint byte_off) {
    return (weight_data[byte_off >> 2] >> ((byte_off & 3) * 8)) & 0xFF;
}

void main() {
    uint row = gl_GlobalInvocationID.x;
    if (row >= pc.out_dim)
        return;

    uint blocks_per_row = pc.in_dim >> 5;  // in_dim / 32
    uint row_bytes = blocks_per_row * 18;
    uint row_byte_off = row * row_bytes;

    float acc = 0.0;

    for (uint b = 0; b < blocks_per_row; b++) {
        uint blk = row_byte_off + b * 18;

        // Read f16 scale from first 2 bytes of block
        uint lo = read_byte(blk);
        uint hi = read_byte(blk + 1);
        float scale = unpackHalf2x16(lo | (hi << 8)).x;

        // Dequantize 32 elements from 16 bytes of packed nibbles
        // ggml layout: low nibbles → elements 0..15, high nibbles → elements 16..31
        uint qs = blk + 2;
        uint base_elem = b * 32;

        for (uint i = 0; i < 16; i++) {
            uint qb = read_byte(qs + i);
            float v0 = (float(qb & 0xF) - 8.0) * scale;   // low nibble → elem i
            float v1 = (float(qb >> 4) - 8.0) * scale;     // high nibble → elem i+16

            acc += v0 * input_vec[base_elem + i];
            acc += v1 * input_vec[base_elem + i + 16];
        }
    }

    output_vec[row] = acc;
}
