#version 450

// Gate scan: compute dot product of each gate vector with the residual stream.
// One invocation per feature. Gate data stored as packed F16 pairs (uint32).
// HiddenDim must be even (2560 for Gemma 3 4B).
//
// Bindings:
//   0 = gate matrix (uint[], packed F16 pairs, row-major: feature * half_hidden + d)
//   1 = residual vector (float[], HiddenDim elements)
//   2 = scores output (float[], FFNWidth elements)
//
// Push constants:
//   hidden_dim_half = HiddenDim / 2

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PushConstants {
    uint hidden_dim_half;  // HiddenDim / 2 (1280 for Gemma 3 4B)
} pc;

layout(std430, binding = 0) readonly buffer GateBuf {
    uint gate_data[];
};

layout(std430, binding = 1) readonly buffer ResidualBuf {
    float residual[];
};

layout(std430, binding = 2) writeonly buffer ScoresBuf {
    float scores[];
};

void main() {
    uint feature = gl_GlobalInvocationID.x;

    // Each feature's gate vector starts at feature * hidden_dim_half uint32s
    uint base = feature * pc.hidden_dim_half;

    float acc = 0.0;

    // Process 2 dimensions per iteration (one packed uint32 = two F16 values)
    for (uint d = 0; d < pc.hidden_dim_half; d++) {
        uint packed = gate_data[base + d];
        vec2 unpacked = unpackHalf2x16(packed);

        uint dim = d * 2;
        acc += unpacked.x * residual[dim];
        acc += unpacked.y * residual[dim + 1];
    }

    scores[feature] = acc;
}
