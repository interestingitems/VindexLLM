#version 450

// Accumulate: weighted sum of top-K down vectors into the residual stream.
// One invocation per hidden dimension. Loops over K winners.
// Down vectors are pre-packed contiguously as F16 pairs (uint32).
//
// Bindings:
//   0 = down_pack (uint[], K * hidden_dim_half packed F16 pairs)
//   1 = activations (float[], K winning scores)
//   2 = residual (float[], HiddenDim — read-modify-write)
//
// Push constants:
//   hidden_dim_half = HiddenDim / 2
//   top_k = number of winners

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PushConstants {
    uint hidden_dim_half;  // HiddenDim / 2
    uint top_k;            // Number of winners (e.g. 128)
} pc;

layout(std430, binding = 0) readonly buffer DownPackBuf {
    uint down_pack[];
};

layout(std430, binding = 1) readonly buffer ActivationsBuf {
    float activations[];
};

layout(std430, binding = 2) buffer ResidualBuf {
    float residual[];
};

void main() {
    uint dim = gl_GlobalInvocationID.x;
    uint hidden_dim = pc.hidden_dim_half * 2;

    if (dim >= hidden_dim)
        return;

    float acc = 0.0;

    // Which half-word pair contains our dimension
    uint half_idx = dim / 2;
    uint half_lane = dim % 2;  // 0 = .x, 1 = .y

    for (uint k = 0; k < pc.top_k; k++) {
        // Down vector k starts at k * hidden_dim_half uint32s
        uint packed = down_pack[k * pc.hidden_dim_half + half_idx];
        vec2 unpacked = unpackHalf2x16(packed);

        float down_val = (half_lane == 0) ? unpacked.x : unpacked.y;
        acc += activations[k] * down_val;
    }

    residual[dim] += acc;
}
