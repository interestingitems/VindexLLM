#version 450
#extension GL_EXT_shader_8bit_storage : require
#extension GL_EXT_shader_explicit_arithmetic_types_int8 : require

// Batched GPU Embedding Lookup (Q8_0): read N rows from Q8_0 embedding table,
// dequantize to F32 with scaling, write to output matrix rows.
// Uses shared-memory scale cache (same technique as matvec_q8_0).
//
// Dispatch: (num_tokens, 1, 1) — one workgroup per token
//   gl_WorkGroupID.x = token index
//
// Bindings:
//   0 = embedding table (int8_t[], raw Q8_0 blocks, row-major)
//   1 = output matrix   (float[], num_tokens x hidden_dim, row-major)
//   2 = token IDs       (uint[], num_tokens entries)
//
// Push constants:
//   dim_param    = hidden_dim (elements per row)
//   embed_scale  = sqrt(hidden_dim) scaling factor
//   num_tokens   = number of tokens to look up

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PushConstants {
    uint  dim_param;     // hidden_dim
    float embed_scale;
    uint  num_tokens;
} pc;

layout(std430, binding = 0) readonly buffer EmbedBuf {
    int8_t embed_bytes[];
};

layout(std430, binding = 1) writeonly buffer OutputBuf {
    float output_mat[];
};

layout(std430, binding = 2) readonly buffer TokenIdsBuf {
    uint token_ids[];
};

shared float blk_scales[256];

void main() {
    uint tok = gl_WorkGroupID.x;
    uint tid = gl_LocalInvocationID.x;

    if (tok >= pc.num_tokens)
        return;

    uint token_id = token_ids[tok];
    uint blocks_per_row = pc.dim_param >> 5;  // hidden_dim / 32
    uint row_byte_off = token_id * blocks_per_row * 34;
    uint out_base = tok * pc.dim_param;

    // Cooperatively load all block scales into shared memory
    for (uint b = tid; b < blocks_per_row; b += 256) {
        uint off = row_byte_off + b * 34;
        uint lo = uint(embed_bytes[off]) & 0xFF;
        uint hi = uint(embed_bytes[off + 1]) & 0xFF;
        blk_scales[b] = unpackHalf2x16(lo | (hi << 8)).x;
    }
    barrier();

    // Dequantize elements with cached scales
    for (uint elem = tid; elem < pc.dim_param; elem += 256) {
        uint blk_idx = elem >> 5;
        float qval = float(embed_bytes[row_byte_off + blk_idx * 34 + 2 + (elem & 31)]);
        output_mat[out_base + elem] = qval * blk_scales[blk_idx] * pc.embed_scale;
    }
}
